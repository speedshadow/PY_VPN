{
  "name": "theme",
  "version": "1.0.0",
  "type": "module",
  "description": "Tailwind CSS for theme app",
  "main": "tailwind.config.js",
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ../static/css/dist/styles.css --minify",
    "watch": "tailwindcss -i ./src/input.css -o ../static/css/dist/styles.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.0.0",
    "tailwindcss": "^3.0.0"
  }
}
